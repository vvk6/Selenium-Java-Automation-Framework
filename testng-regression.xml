<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Final Automation Suite" parallel="classes" thread-count="5">
	<listeners>
		<listener
			class-name="com.mytesting.SeleniumFrameWorkPractice.utils.AnnotationTransformer" />
	</listeners>

	<parameter name="Searchquery" value="sony" />
	<parameter name="ProductNameToAdd" value="hp" />
	<parameter name="browser" value="chrome" />
	<test name="Regression Testing">
		<groups>

			<run>
				<include name="Regression"></include>

			</run>
		</groups>
		<classes>
			<class name="com.mytesting.SeleniumFrameWorkPractice.AddToCart"></class>
			<class name="com.mytesting.SeleniumFrameWorkPractice.BestSellerTest"></class>
			<class name="com.mytesting.SeleniumFrameWorkPractice.EmptyCart"></class>


		</classes>


	</test>


</suite>